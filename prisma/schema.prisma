generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
}

enum ProductCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ProductStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  SOLD
  EXPIRED
  BANNED
  CANCELLED
}

model User {
  // — Identity —
  id       Int     @id @default(autoincrement())
  email    String  @unique
  password String?

  // — Profile —
  fullName String   @map("full_name")
  phone    String?  @db.VarChar(20)
  avatar   String   @default("https://res.cloudinary.com/dazcuspid/image/upload/default_avatar_nj9oa5.avif")
  role     UserRole @default(CUSTOMER)

  // — Location (optional, 2-level structure — for "near you" recommendation) —
  provinceCode  Int?    @map("province_code")
  provinceName  String? @map("province_name")
  wardCode      Int?    @map("ward_code")
  wardName      String? @map("ward_name")
  addressDetail String? @map("address_detail")

  // — Account status —
  isActive Boolean @default(false) @map("is_active")
  isBanned Boolean @default(false) @map("is_banned")

  // — Account activation (email OTP) —
  codeOtp           String?   @map("code_otp") @db.VarChar(6)
  codeOtpExpiration DateTime? @map("code_otp_expiration")

  // — Password reset —
  isOtpVerified Boolean @default(false) @map("is_otp_verified")

  // — Auth tokens —
  hashedRefreshToken String? @map("hashed_refresh_token")

  // — Seller trust signals (recommendation engine, not yet wired up) —
  avgRating      Float @default(0) @map("avg_rating")
  completionRate Float @default(0) @map("completion_rate")
  responseRate   Float @default(0) @map("response_rate")

  // — Relations —
  products               Product[]
  savedProducts          SavedProduct[]
  productViews           ProductView[]
  reviewsWritten         Review[]       @relation("ReviewsWritten")
  reviewsReceived        Review[]       @relation("ReviewsReceived")
  conversationsInitiated Conversation[] @relation("ConversationsInitiated")
  conversationsReceived  Conversation[] @relation("ConversationsReceived")
  messagesSent           Message[]      @relation("MessagesSent")

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Category {
  // — Identity —
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique
  icon String @default("https://res.cloudinary.com/dazcuspid/image/upload/default_category_qswbed.jpg")

  // — Hierarchy —
  parentId Int?       @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  // — Relations —
  products Product[]

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Product {
  // — Identity —
  id          Int     @id @default(autoincrement())
  title       String
  description String  @db.Text
  price       Decimal @db.Decimal(12, 0)

  // — Location (2-level structure, post-2025 administrative merger) —
  provinceCode  Int    @map("province_code")
  provinceName  String @map("province_name")
  wardCode      Int    @map("ward_code")
  wardName      String @map("ward_name")
  addressDetail String @map("address_detail")

  // — Condition & status —
  condition      ProductCondition
  status         ProductStatus    @default(DRAFT)
  rejectedReason String?          @map("rejected_reason")

  // — Monetization —
  expiresAt      DateTime? @map("expires_at")
  boostExpiresAt DateTime? @map("boost_expires_at")

  // — Quality Score (recommendation engine) —
  qualityScore Float @default(0) @map("quality_score")
  viewCount    Int   @default(0) @map("view_count")
  saveCount    Int   @default(0) @map("save_count")

  // — Relations —
  sellerId   Int            @map("seller_id")
  seller     User           @relation(fields: [sellerId], references: [id])
  categoryId Int            @map("category_id")
  category   Category       @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  savedBy    SavedProduct[]
  views      ProductView[]
  reviews    Review[]
  messages   Message[]

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model ProductImage {
  // — Identity —
  id       Int    @id @default(autoincrement())
  url      String
  publicId String @map("public_id")
  order    Int    @default(0)

  // — Relations —
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_images")
}

model SavedProduct {
  // — Relations —
  userId    Int     @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, productId])
  @@map("saved_products")
}

model ProductView {
  // — Identity —
  id        Int    @id @default(autoincrement())
  sessionId String @map("session_id")

  // — Relations —
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    Int?    @map("user_id")
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // — Timestamps —
  viewedAt DateTime @default(now()) @map("viewed_at")

  @@map("product_views")
}

model Review {
  // — Identity —
  id Int @id @default(autoincrement())

  // — Relations —
  reviewerId Int     @map("reviewer_id")
  reviewer   User    @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  sellerId   Int     @map("seller_id")
  seller     User    @relation("ReviewsReceived", fields: [sellerId], references: [id])
  productId  Int     @map("product_id")
  product    Product @relation(fields: [productId], references: [id])

  // — Content —
  rating      Int
  comment     String? @db.Text
  sellerReply String? @map("seller_reply") @db.Text

  // — Moderation —
  isPublished Boolean @default(false) @map("is_published")
  isHidden    Boolean @default(false) @map("is_hidden")

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([reviewerId, sellerId])
  @@map("reviews")
}

model Conversation {
  // — Identity —
  id Int @id @default(autoincrement())

  // — Relations — initiator/recipient are fixed at creation, NOT buyer/seller
  // (a single thread is reused across every product the pair discusses, so
  // who's buying vs selling depends on the product, not on this conversation)
  initiatorId Int  @map("initiator_id")
  initiator   User @relation("ConversationsInitiated", fields: [initiatorId], references: [id])
  recipientId Int  @map("recipient_id")
  recipient   User @relation("ConversationsReceived", fields: [recipientId], references: [id])

  // — Relations —
  messages Message[]

  // — Timestamps — updatedAt bumped on every new message, used to sort inbox
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([initiatorId, recipientId])
  @@map("conversations")
}

model Message {
  // — Identity —
  id Int @id @default(autoincrement())

  // — Relations —
  conversationId Int          @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       Int          @map("sender_id")
  sender         User         @relation("MessagesSent", fields: [senderId], references: [id])

  // Which product this message is about (nullable — a conversation can start or
  // continue without referencing a specific listing). Feeds Reviews' gate check:
  // cross-referenced against Product.sellerId to determine actual buyer/seller
  // role, since Conversation itself no longer tracks that.
  productId Int?     @map("product_id")
  product   Product? @relation(fields: [productId], references: [id])

  // — Content — content stays in the DB even when recalled (soft-hide only,
  // for audit/dispute purposes); the frontend renders "message recalled"
  // in place of content when isRecalled is true. No edit support — see Chat
  // section for why (recall only, no silent rewriting of negotiation history).
  content    String  @db.Text
  isRead     Boolean @default(false) @map("is_read")
  isRecalled Boolean @default(false) @map("is_recalled")

  // — Timestamps —
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}
